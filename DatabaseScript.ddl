comment on table SYS.CDB_2PC_NEIGHBORS is 'information about incoming and outgoing connections for pending transactions in all containers'
/

comment on column SYS.CDB_2PC_NEIGHBORS.IN_OUT is '"in" for incoming connections, "out" for outgoing'
/

comment on column SYS.CDB_2PC_NEIGHBORS.DATABASE is 'in: client database name; out: outgoing db link'
/

comment on column SYS.CDB_2PC_NEIGHBORS.DBUSER_OWNER is 'in: name of local user; out: owner of db link'
/

comment on column SYS.CDB_2PC_NEIGHBORS.INTERFACE is '"C" for request commit, else "N" for prepare or request readonly commit'
/

comment on column SYS.CDB_2PC_NEIGHBORS.DBID is 'the database id at the other end of the connection'
/

comment on column SYS.CDB_2PC_NEIGHBORS.SESS# is 'session number at this database of the connection'
/

comment on column SYS.CDB_2PC_NEIGHBORS.BRANCH is 'transaction branch ID at this database of the connection'
/

comment on column SYS.CDB_2PC_NEIGHBORS.CON_ID is 'container id'
/

comment on table SYS.CDB_2PC_PENDING is 'info about distributed transactions awaiting recovery in all containers'
/

comment on column SYS.CDB_2PC_PENDING.LOCAL_TRAN_ID is 'string of form: n.n.n, n a number'
/

comment on column SYS.CDB_2PC_PENDING.GLOBAL_TRAN_ID is 'globally unique transaction id'
/

comment on column SYS.CDB_2PC_PENDING.STATE is 'collecting, prepared, committed, forced commit, or forced rollback'
/

comment on column SYS.CDB_2PC_PENDING.MIXED is 'yes => part of the transaction committed and part rolled back (commit or rollback with the FORCE option was used)'
/

comment on column SYS.CDB_2PC_PENDING.ADVICE is 'C for commit, R for rollback, else null'
/

comment on column SYS.CDB_2PC_PENDING.TRAN_COMMENT is 'text for "commit work comment <text>"'
/

comment on column SYS.CDB_2PC_PENDING.FAIL_TIME is 'value of SYSDATE when the row was inserted (tx or system recovery)'
/

comment on column SYS.CDB_2PC_PENDING.FORCE_TIME is 'time of manual force decision (null if not forced locally)'
/

comment on column SYS.CDB_2PC_PENDING.RETRY_TIME is 'time automatic recovery (RECO) last tried to recover the transaction'
/

comment on column SYS.CDB_2PC_PENDING.OS_USER is 'operating system specific name for the end-user'
/

comment on column SYS.CDB_2PC_PENDING.OS_TERMINAL is 'operating system specific name for the end-user terminal'
/

comment on column SYS.CDB_2PC_PENDING.HOST is 'name of the host machine for the end-user'
/

comment on column SYS.CDB_2PC_PENDING.DB_USER is 'Oracle user name of the end-user at the topmost database'
/

comment on column SYS.CDB_2PC_PENDING.COMMIT# is 'global commit number for committed transactions'
/

comment on column SYS.CDB_2PC_PENDING.CON_ID is 'container id'
/

