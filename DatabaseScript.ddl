/

comment on column SYS.USER_AUDIT_TRAIL.NEW_OWNER is 'The owner of the object named in the NEW_NAME column'
/

comment on column SYS.USER_AUDIT_TRAIL.NEW_NAME is 'New name of object after RENAME, or name of underlying object (e.g. CREATE INDEX owner.obj_name ON new_owner.new_name)'
/

