/

comment on column SYS.DBA_COMMON_AUDIT_TRAIL.ADMIN_OPTION is 'If role/sys_priv was granted WITH ADMIN OPTON, A/-'
/

comment on column SYS.DBA_COMMON_AUDIT_TRAIL.OS_PRIVILEGE is 'Operating Privilege (SYSDBA/SYSOPER) used in the session. If no privilege is used, it will be NONE'
/

comment on column SYS.DBA_COMMON_AUDIT_TRAIL.GRANTEE is 'The name of the grantee specified in a GRANT/REVOKE statement'
/

comment on column SYS.DBA_COMMON_AUDIT_TRAIL.PRIV_USED is 'System privilege used to perform the action'
/

comment on column SYS.DBA_COMMON_AUDIT_TRAIL.SES_ACTIONS is 'Session summary.  A string of 12 characters, one for each action type, in thisorder: Alter, Audit, Comment, Delete, Grant, Index, Insert, Lock, Rename, Select, Update, Flashback.  Values:  "-" = None, "S" = Success, "F" = Failure, "B" = Both'
/

